@startuml
state STATE_WAITING_FOR_CFUN {
    STATE_WAITING_FOR_CFUN --> STATE_RUNNING: LOCATION_PRIV_CFUN_REQUIRED_SET
}
state STATE_RUNNING {
    state STATE_LOCATION_SEARCH_INACTIVE {
        STATE_LOCATION_SEARCH_INACTIVE --> STATE_LOCATION_SEARCH_ACTIVE: LOCATION_SEARCH_TRIGGER
        STATE_LOCATION_SEARCH_INACTIVE --> STATE_LOCATION_SEARCH_ACTIVE: LOCATION_GNSS_SEARCH_TRIGGER
    }

    state STATE_LOCATION_SEARCH_ACTIVE {
        STATE_LOCATION_SEARCH_ACTIVE : LOCATION_SEARCH_CANCEL / location_request_cancel()
        STATE_LOCATION_SEARCH_ACTIVE --> STATE_LOCATION_SEARCH_INACTIVE: LOCATION_SEARCH_DONE
    }

    [*] --> STATE_LOCATION_SEARCH_INACTIVE
}

[*] --> STATE_WAITING_FOR_CFUN
@enduml

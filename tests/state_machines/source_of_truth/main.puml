@startuml
state STATE_WAITING_FOR_MODULES_INIT
STATE_WAITING_FOR_MODULES_INIT --> STATE_RUNNING: MAIN_MODULES_READY

state STATE_RUNNING {

    state STATE_DISCONNECTED {
        state STATE_DISCONNECTED_SAMPLING
        state STATE_DISCONNECTED_WAITING

        [*] --> STATE_DISCONNECTED_WAITING

        STATE_DISCONNECTED_SAMPLING --> STATE_DISCONNECTED_WAITING: LOCATION_SEARCH_DONE
        STATE_DISCONNECTED_WAITING --> STATE_DISCONNECTED_SAMPLING: TIMER_EXPIRED_SAMPLE_DATA || BUTTON_PRESS_SHORT
        STATE_DISCONNECTED_WAITING --> STATE_DISCONNECTED_WAITING: TIMER_CONFIG_CHANGED
    }

    state STATE_CONNECTED {
        state STATE_CONNECTED_WAITING
        state STATE_CONNECTED_SAMPLING
        state STATE_CONNECTED_SENDING

        [*] --> STATE_CONNECTED_WAITING

        STATE_CONNECTED_WAITING --> STATE_CONNECTED_SAMPLING: TIMER_EXPIRED_SAMPLE_DATA || BUTTON_PRESS_SHORT
        STATE_CONNECTED_WAITING --> STATE_CONNECTED_SENDING: STORAGE_THRESHOLD_REACHED
        STATE_CONNECTED_WAITING --> STATE_CONNECTED_WAITING: TIMER_CONFIG_CHANGED

        STATE_CONNECTED_SAMPLING --> STATE_CONNECTED_WAITING: LOCATION_SEARCH_DONE && previous != STATE_CONNECTED_SENDING
        STATE_CONNECTED_SAMPLING --> STATE_CONNECTED_SENDING: (LOCATION_SEARCH_DONE && previous == STATE_CONNECTED_SENDING) || STORAGE_THRESHOLD_REACHED

        STATE_CONNECTED_SENDING --> STATE_CONNECTED_WAITING: STORAGE_BATCH_CLOSE
        STATE_CONNECTED_SENDING --> STATE_CONNECTED_SAMPLING: TIMER_EXPIRED_SAMPLE_DATA || BUTTON_PRESS_SHORT
    }

    [*] --> STATE_DISCONNECTED

    STATE_DISCONNECTED --> STATE_CONNECTED: CLOUD_CONNECTED
    STATE_CONNECTED --> STATE_DISCONNECTED: CLOUD_DISCONNECTED
}

state STATE_FOTA {

    state STATE_FOTA_DOWNLOADING
    state STATE_FOTA_WAITING_FOR_NETWORK_DISCONNECT
    state STATE_FOTA_WAITING_FOR_NETWORK_DISCONNECT_TO_APPLY_IMAGE
    state STATE_FOTA_APPLYING_IMAGE
    state STATE_FOTA_REBOOTING

    [*] --> STATE_FOTA_DOWNLOADING

    STATE_FOTA_DOWNLOADING --> STATE_FOTA_WAITING_FOR_NETWORK_DISCONNECT: FOTA_SUCCESS_REBOOT_NEEDED
    STATE_FOTA_DOWNLOADING --> STATE_FOTA_WAITING_FOR_NETWORK_DISCONNECT_TO_APPLY_IMAGE: FOTA_IMAGE_APPLY_NEEDED
    STATE_FOTA_WAITING_FOR_NETWORK_DISCONNECT --> STATE_FOTA_REBOOTING: NETWORK_DISCONNECTED
    STATE_FOTA_WAITING_FOR_NETWORK_DISCONNECT_TO_APPLY_IMAGE --> STATE_FOTA_APPLYING_IMAGE: NETWORK_DISCONNECTED
    STATE_FOTA_APPLYING_IMAGE --> STATE_FOTA_REBOOTING: FOTA_SUCCESS_REBOOT_NEEDED
}

[*] --> STATE_WAITING_FOR_MODULES_INIT
STATE_RUNNING --> STATE_FOTA: FOTA_DOWNLOADING_UPDATE
STATE_FOTA --> STATE_RUNNING: FOTA_DOWNLOAD_CANCELED || FOTA_DOWNLOAD_TIMED_OUT || FOTA_DOWNLOAD_FAILED || FOTA_DOWNLOAD_REJECTED

@enduml

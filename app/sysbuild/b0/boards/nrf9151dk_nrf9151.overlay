#include "../../../dts/nrf9151dk_prelude.dtsi"
#include "../../../dts/att_flash_partitions.dtsi"

/* Give b0 full secure SRAM. */
&sram0_s {
	reg = <0x0 0x40000>;
};

/ {
	chosen {
		zephyr,code-partition = &b0_partition;
	};
};

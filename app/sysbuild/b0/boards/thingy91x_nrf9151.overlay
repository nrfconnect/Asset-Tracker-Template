#include "../../../dts/thingy91x_prelude.dtsi"
#include "../../../dts/att_flash_partitions.dtsi"

/* b0 runs as a secure-only image, so give it the full SRAM. */
&sram0_s {
	reg = <0x0 0x40000>;
};

/ {
	chosen {
		zephyr,code-partition = &b0_partition;
	};
};

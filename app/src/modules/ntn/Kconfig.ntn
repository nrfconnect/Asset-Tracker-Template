menuconfig APP_NTN
	bool "NTN"
	default y if APP_NTN_MODE

if APP_NTN

config APP_NTN_THREAD_STACK_SIZE
	int "NTN module thread stack size"
	default 8192


config APP_NTN_LOCATION_VALIDITY_TIME_SECONDS
	int "NTN location validity time"
	default 0
	help
	  Location validity in seconds for NTN mode. The value depends on the use-case and what NTN constellation is used.
	  For example, if the device is stationary and using GEO, the value can be longer.
	  If the device is moving and using LEO, the value should be shorter.
	  The distance the device is expected to travel must also be considered.
	  Default is set to 0 for infinite validity.

config APP_NTN_BANDLOCK_ENABLE
	bool "Enable NTN band lock"
	help
	  Enable band lock for NTN mode.

if APP_NTN_BANDLOCK_ENABLE

config APP_NTN_BANDLOCK
	int "NTN band to lock to"
	default 265
	help
	  Band number to lock NTN mode to.

endif # APP_NTN_BANDLOCK_ENABLE

config APP_NTN_CHANNEL_SELECT_ENABLE
	bool "Enable NTN channel select"
	help
	  Enable channel selection for NTN mode.

if APP_NTN_CHANNEL_SELECT_ENABLE

config APP_NTN_CHANNEL_SELECT
	int "NTN channel to select"
	default 1
	help
	  Channel number to select in NTN mode.

endif # APP_NTN_CHANNEL_SELECT_ENABLE

config APP_NTN_SERVER_ADDR
	string "NTN server address"
	default ""
	help
	  IP address of the NTN server to connect to.

config APP_NTN_SERVER_PORT
	int "NTN server port"
	default 0
	help
	  Port number of the NTN server to connect to.

config APP_NTN_LEO
	bool "Enable LEO NTN"
	help
	  Enable LEO NTN.

if APP_NTN_LEO

config APP_NTN_LEO_TIME_OF_PASS
	string "Time of pass of LEO satellite (UTC)"
	default "2025-09-29-10:20:00"
	help
	  Pre-provision ATT with time of pass in UTC using format: YYYY-MM-DD HH:mm:ss
	  Example: 2025-09-29 12:00:00 for September 29, 2025 12:00:00 UTC

endif # APP_NTN_LEO

config APP_NTN_THINGY_ROCKS_ENDPOINT
	bool "Use world.thingy.rocks endpoint"
	default y
	help
	  Use world.thingy.rocks endpoint.

config APP_NTN_TIMER_NTN_VALUE_SECONDS
	int "Timer value for NTN activation"
	default 20
	help
	  Timer value for NTN activation

config APP_NTN_WATCHDOG_TIMEOUT_SECONDS
	int "NTN module watchdog timeout in seconds"
	default 300
	help
	  If the NTN module thread is stuck for this amount of time,
	  the device will reset.

config APP_NTN_MSG_PROCESSING_TIMEOUT_SECONDS
	int "Maximum time in seconds allowed for processing a single message"
	default 240
	help
	  Maximum time allowed for processing a single message in the NTN module.
	  Must be less than APP_NTN_WATCHDOG_TIMEOUT_SECONDS.

config APP_NTN_SEND_1200_BYTES
	bool "Send 1200 bytes"
	default n
	help
	  Send big amount of data.

config APP_NTN_DEFAULT_LATITUDE_1000000
	int "Default latitude for fallback location (multiplied by 1000000)"
	default 63421007
	help
	  Default latitude value used when GNSS fix is not available.
	  The value is multiplied by 1000000 to handle decimal places.
	  For example, 63.421007 is represented as 63421007.

config APP_NTN_DEFAULT_LONGITUDE_1000000
	int "Default longitude for fallback location (multiplied by 1000000)"
	default 10436379
	help
	  Default longitude value used when GNSS fix is not available.
	  The value is multiplied by 1000000 to handle decimal places.
	  For example, 10.436379 is represented as 10436379.

config APP_NTN_DEFAULT_ALTITUDE_1000
	int "Default altitude for fallback location (multiplied by 1000)"
	default 130798
	help
	  Default altitude value (in meters) used when GNSS fix is not available.
	  The value is multiplied by 1000 to handle decimal places.
	  For example, 130.798 is represented as 130798.

config APP_NTN_USB_KEEPALIVE_ENABLE
	bool "Enable USB keepalive"
	help
	  Enable USB keepalive feature. This is needed for Windows 11 setup to keep
	  the USB connection alive. Not needed for other operating systems.


module = APP_NTN
module-str = NTN
source "subsys/logging/Kconfig.template.log_config"

endif # APP_NTN

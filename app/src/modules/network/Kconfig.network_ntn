menu "Non-Terrestrial Network (NTN) support"

config APP_NETWORK_TN_SIM_TYPE
	int "SIM type for TN"
	default 0
	range 0 1
	help
	  SIM type for TN. 0 for physical SIM, 1 for soft SIM.

config APP_NETWORK_NTN_SIM_TYPE
	int "SIM type for NTN"
	default 0
	range 0 1
	help
	  SIM type for NTN. 0 for physical SIM, 1 for soft SIM.

config APP_NETWORK_NTN_PERIODIC_TN_SEARCH_INTERVAL_SECONDS
	int "Periodic terrestrial network search interval in seconds"
	default 3600
	help
	  Interval in seconds between terrestrial network
	  searches while waiting for a LEO satellite pass.

choice APP_NETWORK_NTN_LOCATION_FAILED_HANDLING
	prompt "Location failed handling"
	default APP_NETWORK_NTN_LOCATION_FAILED_LEO_THEN_GEO
	help
	  What to do when location request failed and no new location data is available for
	  LEO satellite pass prediction and search.

config APP_NETWORK_NTN_LOCATION_FAILED_USE_LEO
	bool "LEO with previous location"
	help
	  Use previous location data for LEO satellite pass prediction and search.

config APP_NETWORK_NTN_LOCATION_FAILED_USE_GEO
	bool "Fallback to GEO"
	help
	  Fallback to GEO satellite search when location failed. The previous location data
	  will be used by the modem.

config APP_NETWORK_NTN_LOCATION_FAILED_LEO_THEN_GEO
	bool "LEO then GEO"
	help
	  First try to search for a LEO satellite pass with the previous location data. If no LEO
	  satellite pass is found, fall back to GEO satellite search.
	  Note that TLE data must be available and usable accoring to
	  CONFIG_APP_NETWORK_NTN_TLE_STALE_HANDLING.
endchoice # APP_NETWORK_NTN_LOCATION_FAILED_HANDLING

config APP_NETWORK_NTN_USE_STATIC_LOCATION_ON_GNSS_FAILURE
	bool "Use static location on GNSS failure"
	help
	  Use a static location for the device on GNSS failure. The module will continue to use the static location until the location is updated.

config APP_NETWORK_NTN_STATIC_LOCATION_LATITUDE
	int "Static location latitude (degrees x 1 000 000)"
	help
	  Static location latitude in degrees multiplied by 1000000.
	  For example, 63.418575 degrees is 63418575.

config APP_NETWORK_NTN_STATIC_LOCATION_LONGITUDE
	int "Static location longitude (degrees x 1 000 000)"
	help
	  Static location longitude in degrees multiplied by 1000000.
	  For example, 10.401742 degrees is 10401742.

config APP_NETWORK_NTN_STATIC_LOCATION_ALTITUDE
	int "Static location altitude in meters"
	help
	  Static location altitude in meters above sea level.

config APP_NETWORK_NTN_TLE_STALE_HOURS
	int "TLE freshness threshold in hours"
	default 168
	help
	  Maximum age in hours before TLE (Two-Line Element) orbital data
	  is considered stale. Fresh TLE enables LEO satellite pass
	  prediction via SGP4. When TLE is stale, the module falls back
	  to GEO satellite search. A GEO connection can refresh TLE via
	  the cloud. Default is 168 hours (1 week).
	  After the TLE is considered stale, the module behave according to the TLE stale handling
	  configuration in the APP_NETWORK_NTN_TLE_STALE_HANDLING choice.

choice APP_NETWORK_NTN_TLE_STALE_HANDLING
	prompt "TLE stale handling"
	default APP_NETWORK_NTN_TLE_STALE_USE_OLD_TLE
	help
	  What to do when TLE is stale.

config APP_NETWORK_NTN_TLE_STALE_USE_GEO
	bool "Fallback to GEO satellite search"
	help
	  Fallback to GEO satellite search when TLE is stale. The module will attempt to download
	  new TLE from the cloud over GEO connection.

config APP_NETWORK_NTN_TLE_STALE_USE_OLD_TLE
	bool "Use old TLE"
	help
	  Use old TLE when TLE is stale. The module will continue to use the old TLE until
	  the new TLE is available. SGP4 will be used to predict the satellite position, with an
	  extra margin of 30 seconds added per week of outdated TLE.
	  This means that the module will start searching for the satellite 30 seconds before the
	  predicted pass starts for the first week, 1 minute before the predicted pass starts for the
	  second week, and so on.

config APP_NETWORK_NTN_TLE_STALE_NO_NTN
	bool "Do not use NTN if TLE is stale"
	help
	  Do not use NTN if TLE is stale. The module will continue to periodically search for
	  terrestrial networks instead of using NTN.

endchoice # APP_NETWORK_NTN_TLE_STALE_HANDLING

config APP_NETWORK_NTN_BANDLOCK
	bool "Enable NTN band lock"
	help
	  Use abnd lock for NTN searches. This will llimit the number of bands that the modem can
	  use for NTN searches and may reduce the search time.
	  Note that constellations may support different bands in different regions.

config APP_NETWORK_NTN_BANDLOCK_BANDS
	string "NTN band lock bands"
	depends on APP_NETWORK_NTN_BANDLOCK
	help
	  NTN band lock bands in string format as a comma-separated list of band numbers.
	  The band lock applies only to NTN searches.

config APP_NETWORK_NTN_CHANNEL_SELECT
	bool "Enable NTN channel select"
	help
	  Use channel select for NTN searches. This will limit the number of channels that the modem can
	  use for NTN searches and may reduce the search time.
	  Note that constellations may support different channels in different regions.

config APP_NETWORK_NTN_CHANNEL_SELECT_CHANNEL
	int "NTN channel select channel"
	depends on APP_NETWORK_NTN_CHANNEL_SELECT
	help
	  NTN channel select channel.

endmenu # Non-Terrestrial Network (NTN) support
